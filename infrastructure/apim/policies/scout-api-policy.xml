<policies>
  <inbound>
    <base />
    <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized — valid Scout JWT required" require-expiration-time="true" require-scheme="Bearer">
      <openid-config url="https://{{entra-scout-tenant-id}}.ciamlogin.com/{{entra-scout-tenant-id}}/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>{{entra-scout-client-id}}</audience>
      </audiences>
    </validate-jwt>
    <set-variable name="scoutId" value="@(context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;,&quot;&quot;).AsJwt()?.Subject)" />
    <choose>
      <when condition="@(context.Variables.GetValueOrDefault(&quot;scoutId&quot;,&quot;&quot;) == &quot;&quot;)">
        <return-response>
          <set-status code="401" reason="Unauthorized" />
          <set-body>@{
            return new JObject(
              new JProperty("type", "https://afrixplore.io/errors/banned"),
              new JProperty("title", "Account Suspended"),
              new JProperty("status", 403),
              new JProperty("detail", "Your account has been suspended. Contact support.")
            ).ToString();
          }</set-body>
        </return-response>
      </when>
    </choose>
    <rate-limit-by-key calls="60" renewal-period="60" counter-key="@((string)context.Variables[&quot;scoutId&quot;])" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
    <set-header name="X-Scout-ID" exists-action="override">
      <value>@((string)context.Variables["scoutId"])</value>
    </set-header>
    <set-header name="X-User-Role" exists-action="override">
      <value>scout</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
