{
  "name": "@afrixplore/payment-service",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "coverageThreshold": {
      "global": {
        "lines": 50,
        "functions": 50
      },
      "./src/config/": {
        "lines": 80,
        "functions": 80
      }
    },
    "coveragePathIgnorePatterns": ["/node_modules/", "/dist/"]
  },
  "dependencies": {
    "@afrixplore/config": "workspace:*",
    "@afrixplore/validation": "workspace:*",
    "@azure/identity": "^4.1.0",
    "@azure/service-bus": "^7.9.4",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.11.5",
    "stripe": "^16.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8.57.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
