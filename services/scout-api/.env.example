# Database
DATABASE_URL=postgresql://user:password@host:5432/afrixplore?sslmode=require

# Azure Entra CIAM (Scout tenant — separate from subscriber tenant)
ENTRA_SCOUT_TENANT_ID=
ENTRA_SCOUT_CLIENT_ID=

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://platform.afrixplore.io

# Port
PORT=3000
