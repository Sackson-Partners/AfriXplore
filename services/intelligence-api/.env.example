# Database
DATABASE_URL=postgresql://user:password@host:5432/afrixplore?sslmode=require

# Azure Entra (Subscriber tenant)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# Azure Service Bus
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://platform.afrixplore.io

# Port
PORT=3001
