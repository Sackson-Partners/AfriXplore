# ── Database ──────────────────────────────────────────────────────────────────
AZURE_POSTGRESQL_CONNECTION_STRING=postgresql://ainuser:password@psql-ain-dev.postgres.database.azure.com:5432/ain?sslmode=require

# Optional: Azure PostgreSQL SSL certificate (for production SSL validation)
# Download from: https://learn.microsoft.com/en-us/azure/postgresql/flexible-server/concepts-networking#downloading-root-ca-certificates-and-updating-application-clients-in-certificate-pinning-scenarios
# POSTGRES_SSL_CERT=/path/to/DigiCertGlobalRootCA.crt.pem

# ── Azure Storage ─────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=staindev
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_MSIM=msim-archives

# ── Azure Key Vault ───────────────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://kv-ain-dev.vault.azure.net/

# ── Azure Entra External ID (subscribers + admins) ────────────────────────────
AZURE_ENTRA_TENANT_ID=
AZURE_ENTRA_CLIENT_ID=
AZURE_ENTRA_CLIENT_SECRET=

# ── Azure AI Search ───────────────────────────────────────────────────────────
AZURE_AI_SEARCH_ENDPOINT=https://srch-ain-dev.search.windows.net
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX_NAME=mines-index

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_

# ── Mapbox ────────────────────────────────────────────────────────────────────
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoiYWluLXBsYXRmb3JtIn0.

# ── Frontend (public env vars) ────────────────────────────────────────────────
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_MSIM_API_URL=http://localhost:3002
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiYWluLXBsYXRmb3JtIn0.
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ── MSIM API ──────────────────────────────────────────────────────────────────
MSIM_API_PORT=3002
PORT=3002
NODE_ENV=development

# ── Convergence Engine (MSIM-GeoSwarm Integration) ────────────────────────────
CONVERGENCE_ENGINE_URL=http://localhost:3005

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
# AZURE_OPENAI_KEY=your-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4-msim
# Maximum characters to send to OpenAI (gpt-4-turbo supports ~96,000 chars)
OPENAI_MAX_DOCUMENT_CHARS=12000

# Azure Document Intelligence (Form Recognizer)
# AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-formrecognizer.cognitiveservices.azure.com/
# AZURE_FORM_RECOGNIZER_KEY=your-key-here

# Azure Maps
# AZURE_MAPS_KEY=your-maps-key-here

# Service Bus (for async job processing)
# SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
