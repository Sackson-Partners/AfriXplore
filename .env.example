# ═══════════════════════════════════════════════════════════
# AfriXplore — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── AZURE IDENTITY ─────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ─── DATABASE ────────────────────────────────────────────────
DATABASE_URL=postgresql://afrixploreAdmin:password@psql-afrixplore-dev-saf.postgres.database.azure.com:5432/afrixplore?sslmode=require

# ─── AZURE SERVICE BUS ───────────────────────────────────────
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://sb-afrixplore-dev.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...

# ─── AZURE STORAGE ───────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=stafrixploredevsa
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ─── AZURE KEY VAULT ─────────────────────────────────────────
KEY_VAULT_URI=https://kv-afrixplore-dev.vault.azure.net/

# ─── ENTRA EXTERNAL ID — SCOUTS ──────────────────────────────
ENTRA_SCOUT_TENANT_ID=your-scout-tenant-id
ENTRA_SCOUT_CLIENT_ID=your-scout-client-id
# Scout tenant domain: afrixplore-scouts-dev.ciamlogin.com

# ─── ENTRA EXTERNAL ID — PLATFORM (B2B) ─────────────────────
ENTRA_PLATFORM_TENANT_ID=your-platform-tenant-id
ENTRA_PLATFORM_CLIENT_ID=your-platform-client-id
ENTRA_PLATFORM_CLIENT_SECRET=your-platform-client-secret

# ─── SIGNALR ─────────────────────────────────────────────────
SIGNALR_CONNECTION_STRING=Endpoint=https://sigr-afrixplore-dev.service.signalr.net;AccessKey=...

# ─── AI / COGNITIVE SERVICES ─────────────────────────────────
CUSTOM_VISION_TRAINING_ENDPOINT=https://afrixplore-cv-training-dev.cognitiveservices.azure.com/
CUSTOM_VISION_TRAINING_KEY=your-cv-training-key
CUSTOM_VISION_PREDICTION_ENDPOINT=https://afrixplore-cv-prediction-dev.cognitiveservices.azure.com/
CUSTOM_VISION_PREDICTION_KEY=your-cv-prediction-key
CUSTOM_VISION_PROJECT_ID=your-project-guid
CUSTOM_VISION_PUBLISHED_NAME=mineral-id-v1
CUSTOM_VISION_PREDICTION_RESOURCE_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.CognitiveServices/accounts/cv-afrixplore-prediction-dev

AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=southafricanorth

AZURE_OPENAI_ENDPOINT=https://afrixplore-openai-dev.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://afrixplore-docint-dev.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-docint-key

# ─── APPLICATION INSIGHTS ────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ─── PAYMENT PROVIDERS ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

AFRICAS_TALKING_API_KEY=your-at-api-key
AFRICAS_TALKING_USERNAME=sandbox

MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_API_USER=your-mtn-api-user
MTN_MOMO_API_KEY=your-mtn-api-key

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...

# ─── FRONTEND (NEXT.JS) ──────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
NEXT_PUBLIC_ENTRA_CLIENT_ID=your-platform-client-id
NEXT_PUBLIC_ENTRA_TENANT_ID=your-platform-tenant-id
NEXT_PUBLIC_SIGNALR_URL=https://sigr-afrixplore-dev.service.signalr.net
NEXT_PUBLIC_API_URL=https://apim-afrixplore-dev.azure-api.net
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3005
NEXT_PUBLIC_ENVIRONMENT=development

# ─── GITHUB ACTIONS SECRETS (reference only) ─────────────────
# AZURE_CREDENTIALS_DEV        — az ad sp create-for-rbac output (dev)
# AZURE_CREDENTIALS_STAGING    — az ad sp create-for-rbac output (staging)
# AZURE_CREDENTIALS_PRODUCTION — az ad sp create-for-rbac output (production)
# VERCEL_TOKEN                 — Vercel API token
# VERCEL_ORG_ID                — Vercel org ID
# VERCEL_PROJECT_ID_PLATFORM   — platform-web project ID
# VERCEL_PROJECT_ID_ADMIN      — admin-web project ID
# SLACK_WEBHOOK_URL            — Slack incoming webhook
# CODECOV_TOKEN                — Codecov upload token
# EXPO_TOKEN                   — EAS CLI token

# ─── LOCAL DEVELOPMENT ───────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006
API_BASE_URL=http://localhost:3000
