# ═══════════════════════════════════════════════════════════
# AfriXplore — Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── AZURE IDENTITY ─────────────────────────────────────────
AZURE_TENANT_ID=89190235-0737-4836-b894-5c9d8afb00c3
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=e919967a-c8ff-4896-977b-360167fa1a84

# ─── DATABASE ────────────────────────────────────────────────
DATABASE_URL=postgresql://afrixploreAdmin:password@psql-afrixplore-staging-saf.postgres.database.azure.com:5432/afrixplore?sslmode=require

# ─── AZURE SERVICE BUS ───────────────────────────────────────
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://sb-afrixplore-staging.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=...

# ─── AZURE STORAGE ───────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ─── AZURE KEY VAULT ─────────────────────────────────────────
KEY_VAULT_URI=https://kv-afrixplore-staging.vault.azure.net/

# ─── ENTRA EXTERNAL ID — SCOUTS ──────────────────────────────
ENTRA_SCOUT_TENANT_ID=your-scout-tenant-id
ENTRA_SCOUT_CLIENT_ID=your-scout-client-id
# Scout tenant domain: afrixplore-scouts-staging.ciamlogin.com

# ─── ENTRA EXTERNAL ID — PLATFORM (B2B) ─────────────────────
ENTRA_PLATFORM_TENANT_ID=89190235-0737-4836-b894-5c9d8afb00c3
ENTRA_PLATFORM_CLIENT_ID=your-platform-app-client-id
ENTRA_PLATFORM_CLIENT_SECRET=your-platform-client-secret

# ─── SIGNALR ─────────────────────────────────────────────────
# Backend services use the connection string:
AZURE_SIGNALR_CONNECTION_STRING=Endpoint=https://sigr-afrixplore-staging.service.signalr.net;AccessKey=...;Version=1.0;
# Frontend uses the hub URL directly:
# NEXT_PUBLIC_SIGNALR_HUB_URL=https://sigr-afrixplore-staging.service.signalr.net/client/?hub=dashboard-hub

# ─── APPLICATION INSIGHTS ────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=a3baffae-ced6-4b85-8be9-b31668a51648;IngestionEndpoint=https://southafricanorth-1.in.applicationinsights.azure.com/;LiveEndpoint=https://southafricanorth.livediagnostics.monitor.azure.com/;ApplicationId=864a3bb4-378b-41a5-9181-049d94a6cc8c

# ─── AI / COGNITIVE SERVICES ─────────────────────────────────
CUSTOM_VISION_TRAINING_ENDPOINT=https://afrixplore-cv-training-staging.cognitiveservices.azure.com/
CUSTOM_VISION_TRAINING_KEY=your-cv-training-key
CUSTOM_VISION_PREDICTION_ENDPOINT=https://afrixplore-cv-prediction-staging.cognitiveservices.azure.com/
CUSTOM_VISION_PREDICTION_KEY=your-cv-prediction-key
CUSTOM_VISION_PROJECT_ID=your-project-guid
CUSTOM_VISION_PUBLISHED_NAME=mineral-id-v1
CUSTOM_VISION_PREDICTION_RESOURCE_ID=/subscriptions/e919967a-c8ff-4896-977b-360167fa1a84/resourceGroups/afrixplore-rg/providers/Microsoft.CognitiveServices/accounts/cv-afrixplore-prediction-staging

AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=southafricanorth

AZURE_OPENAI_ENDPOINT=https://afrixplore-openai-staging.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://afrixplore-docint-staging.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-docint-key

# ─── PAYMENT PROVIDERS ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

AFRICAS_TALKING_API_KEY=your-at-api-key
AFRICAS_TALKING_USERNAME=sandbox

MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_API_USER=your-mtn-api-user
MTN_MOMO_API_KEY=your-mtn-api-key

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...

# ─── FRONTEND (NEXT.JS — see apps/platform-web/.env.example) ─
NEXT_PUBLIC_API_URL=https://ca-intelligence-api-staging.politesand-e98d8f92.southafricanorth.azurecontainerapps.io
NEXT_PUBLIC_APP_URL=https://platform.afrixplore.io
NEXT_PUBLIC_AZURE_CLIENT_ID=your-platform-app-client-id
NEXT_PUBLIC_AZURE_TENANT_ID=89190235-0737-4836-b894-5c9d8afb00c3
NEXT_PUBLIC_SIGNALR_HUB_URL=https://sigr-afrixplore-staging.service.signalr.net/client/?hub=dashboard-hub
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3005
NEXT_PUBLIC_ENVIRONMENT=staging

# ─── GITHUB ACTIONS SECRETS (reference only) ─────────────────
# AZURE_CREDENTIALS            — az ad sp create-for-rbac output (staging)
# AZURE_CREDENTIALS_STAGING    — az ad sp create-for-rbac output (staging)
# VERCEL_TOKEN                 — Vercel API token
# VERCEL_ORG_ID                — Vercel org ID (sacksons-projects)
# VERCEL_PROJECT_ID_PLATFORM   — prj_Wym5Tgy2eOuDTdRi6N9V3iRyk8e8
# VERCEL_PROJECT_ID_ADMIN      — prj_ZNOZ3vPjN9cIXIyKBO7kMds4MWvv
# SLACK_WEBHOOK_URL            — Slack incoming webhook
# EXPO_TOKEN                   — EAS CLI token

# ─── LOCAL DEVELOPMENT ───────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:3006
API_BASE_URL=http://localhost:3000
